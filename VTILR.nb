 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Lambda]", "[", "t_", "]"}], "=", 
    RowBox[{"\[Lambda]0", "+", 
     RowBox[{"\[Delta]\[Lambda]", " ", 
      FractionBox["t", "\[Tau]"]}], "+", 
     RowBox[{
      FractionBox["\[Delta]\[Lambda]", 
       RowBox[{"4", "\[Tau]", " ", "\[Lambda]0"}]], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"DiracDelta", "[", "t", "]"}], "-", 
        RowBox[{"DiracDelta", "[", 
         RowBox[{"\[Tau]", "-", "t"}], "]"}]}], ")"}]}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"\[Sigma]", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Assuming", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Tau]", ">", "0"}], ",", 
         RowBox[{"0", "<=", "t", "<=", "\[Tau]"}], ",", 
         RowBox[{"0", "<=", "u", "<=", "\[Tau]"}], ",", 
         RowBox[{"\[Lambda]0", ">", "0"}]}], "}"}], ",", 
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{"Expand", "[", 
          RowBox[{"\[Beta]", " ", 
           RowBox[{"qi", "^", "2"}], 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"qi", " ", 
