Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"g", ",", "J"}], "]"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Epsilon]", "[", "n_", "]"}], "=", 
   RowBox[{"2", "J", 
    SqrtBox[
     RowBox[{"1", "+", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"g", "/", "J"}], ")"}], "2"], "-", 
      RowBox[{"2", 
       RowBox[{"(", 
        RowBox[{"g", "/", "J"}], ")"}], 
       RowBox[{"Cos", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", "n"}], "-", "1"}], ")"}], 
         RowBox[{"\[Pi]", "/", "N0"}]}], "]"}]}]}]]}]}], 
  ";"}], "\[IndentingNewLine]", 
