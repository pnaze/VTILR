         RowBox[{"\[Tau]", ",", 
          RowBox[{"Mean", "[", "data4", "]"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"data6", "=", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"data6", ",", 
        RowBox[{"{", 
         RowBox[{"\[Tau]", ",", 
          RowBox[{"Variance", "[", "data4", "]"}]}], "}"}]}], "]"}]}], ";"}], 
    "\[IndentingNewLine]", "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"\[Tau]", ",", "0.001", ",", "10.2", ",", "step"}], "}"}]}], 
