  RowBox[{"Do", "[", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Do", "[", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"qi", "=", 
         RowBox[{"RandomVariate", "[", 
          RowBox[{"NormalDistribution", "[", 
           RowBox[{"0", ",", 
            RowBox[{"1", "/", 
             RowBox[{"(", 
              RowBox[{"\[Beta]", " ", "\[Lambda]0"}], ")"}]}]}], "]"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"pi", "=", 
         RowBox[{"RandomVariate", "[", 
          RowBox[{"NormalDistribution", "[", 
           RowBox[{"0", ",", 
            RowBox[{"1", "/", "\[Beta]"}]}], " ", "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"Wqs", "=", 
         RowBox[{
          FractionBox["\[Delta]\[Lambda]", 
           RowBox[{"2", " ", "\[Lambda]0"}]], " ", 
          RowBox[{"(", 
           RowBox[{
            FractionBox[
             SuperscriptBox["pi", "2"], "2"], "+", 
            FractionBox[
             RowBox[{
              SuperscriptBox["qi", "2"], " ", "\[Lambda]0"}], "2"]}], 
           ")"}]}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"data4", "=", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"data4", ",", "Wqs"}], "]"}]}], ";"}], 
