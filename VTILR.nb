                RowBox[{
                 SqrtBox["\[Lambda]0"], " ", 
                 RowBox[{"(", 
                  RowBox[{"t", "-", "u"}], ")"}]}], "]"}]}], "+", 
              RowBox[{"pi", " ", 
               RowBox[{
                RowBox[{"Sin", "[", 
                 RowBox[{
                  SqrtBox["\[Lambda]0"], 
                  RowBox[{"(", 
                   RowBox[{"t", "-", "u"}], ")"}]}], "]"}], "/", 
                SqrtBox["\[Lambda]0"]}]}]}], ")"}], "^", "2"}], 
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"\[Lambda]", "[", "t", "]"}], ",", "t"}], "]"}], 
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"\[Lambda]", "[", "u", "]"}], ",", "u"}], "]"}]}], "]"}],
          ",", 
